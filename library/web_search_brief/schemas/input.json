{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["query"],
  "additionalProperties": false,
  "properties": {
    "query": {
      "type": "string",
      "minLength": 2
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 15,
      "default": 8
    },
    "kind": {
      "type": "string",
      "enum": ["generic", "restaurant", "hotel"],
      "default": "generic"
    }
  }
}
